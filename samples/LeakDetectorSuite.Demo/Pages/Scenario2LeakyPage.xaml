<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeakDetector.Demo.Scenario2LeakyPage"
             Title="S2 Static Event Leak">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="Scenario 2: Static Event Leak" Style="{StaticResource PageTitleStyle}" />
            <Label Text="This page never unsubscribes from a static event, so the page and binding context stay alive after navigation."
                   Style="{StaticResource BodyStyle}" />
            <Button Text="Take Before Snapshot" Clicked="OnTakeSnapshot" Style="{StaticResource ActionButtonStyle}" />
            <Button Text="Go Back (NO cleanup)" Clicked="OnGoBack" Style="{StaticResource ActionButtonStyle}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
