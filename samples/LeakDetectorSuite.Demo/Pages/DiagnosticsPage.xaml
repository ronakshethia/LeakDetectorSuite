<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LeakDetector.Demo.DiagnosticsPage"
             Title="Diagnostics Log">
    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="14">
        <Label Text="Diagnostics Log" Style="{StaticResource PageTitleStyle}" />
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Label Text="All LeakDetector, Perf, and ThreadGuard output is mirrored here live."
                   Style="{StaticResource BodyStyle}" />
            <Button Grid.Column="1" Text="Clear" Clicked="OnClear" Style="{StaticResource ActionButtonStyle}" />
        </Grid>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Entries}">
            <CollectionView.EmptyView>
                <Label Text="No diagnostics yet." Style="{StaticResource BodyStyle}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="{StaticResource PanelBackgroundColor}"
                           BorderColor="{StaticResource BorderColor}"
                           CornerRadius="14"
                           HasShadow="False"
                           Padding="12"
                           Margin="0,0,0,10">
                        <Grid ColumnDefinitions="70,*" RowDefinitions="Auto,Auto" ColumnSpacing="10">
                            <Label Text="{Binding LevelTag}" TextColor="{Binding LevelColor}" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding Timestamp}" TextColor="{StaticResource SecondaryTextColor}" FontSize="12" />
                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Message}" TextColor="{StaticResource PrimaryTextColor}" LineBreakMode="WordWrap" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
